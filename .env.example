# Evaluation Engine Configuration
# Options: gemini, llama, openai, deepseek
EVAL_ENGINE=llama
EXTRACT_ENGINE=llama

GEMINI_API_KEY=Your Gemini Key Here
GEMINI_MODEL_FOR_EXTRACTION=gemini-2.5-flash-lite
GEMINI_MODEL_FOR_EVALUATION=gemini-2.5-flash

OLLAMA_HOST=http://localhost:11434

LLAMA_MODEL_FOR_EXTRACTION=llama3.2:3b
LLAMA_MODEL_FOR_EVALUATION=llama3.1:8b

OPENAI_API_KEY=Your OpenAI API Key Here
OPENAI_MODEL_FOR_EXTRACTION=gpt-4.1-nano
OPENAI_MODEL_FOR_EVALUATION=gpt-4.1-mini

DEEPSEEK_API_KEY=Your DeepSeek API Key Here
DEEPSEEK_MODEL_FOR_EXTRACTION=deepseek-v4-flash
DEEPSEEK_MODEL_FOR_EVALUATION=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# passed through request header 'X-API-Key'
API_KEY=Your API Key